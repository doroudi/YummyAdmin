{
  "type": "module",
  "private": false,
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "build": "vite build --base=/ --mode mocking",
    "dev": "vite --open --port 7000  --mode development",
    "dev:mock": "vite --open --port 7000 --mode mocking",
    "test": "vitest",
    "test:unit": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "up": "taze major -I",
    "check": "biome check --write ./src",
    "lint": "biome lint --write ./src",
    "prepare": "husky || true"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm check . && git add -A ."
    }
  },
  "dependencies": {
    "@unhead/vue": "^1.11.20",
    "@unocss/reset": "^66.5.11",
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/core": "^10.11.1",
    "@vueuse/head": "^1.3.1",
    "apexcharts": "^4.7.0",
    "axios": "^0.27.2",
    "moment": "^2.30.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-demi": "^0.14.10",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue3-apexcharts": "^1.10.0",
    "vue3-map-chart": "^0.0.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@faker-js/faker": "^8.4.1",
    "@intlify/unplugin-vue-i18n": "^0.12.3",
    "@types/nprogress": "^0.2.3",
    "@vicons/fluent": "^0.12.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue-macros/volar": "^3.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "husky": "^9.1.7",
    "lodash": "^4.17.21",
    "msw": "^2.12.6",
    "naive-ui": "^2.43.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pnpm": "^9.15.9",
    "sass": "^1.97.1",
    "taze": "^0.11.4",
    "typescript": "^5.9.3",
    "unocss": "^66.5.11",
    "unplugin-auto-import": "^0.17.8",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-vue-macros": "^2.14.5",
    "unplugin-vue-router": "^0.8.8",
    "vite": "npm:rolldown-vite@^7.3.0",
    "vite-plugin-pages": "^0.33.2",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vitest": "^0.33.0",
    "vue-tsc": "^2.2.12"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
